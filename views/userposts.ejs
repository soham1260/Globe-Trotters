<%- include("partials/header"); -%>

<%  posts.forEach(function(post){ %>

    <h1><%=post.title%></h1>
    <p>
    <%=post.content.substring(0, 150)%>
    <%if(post.content.length>150){%>
    <a href="/posts/<%=post._id%>">...Read More</a>
    <%}%>
    </p>


    <% }) %>

<%- include("partials/footer"); -%>
